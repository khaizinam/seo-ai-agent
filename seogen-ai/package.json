{
  "name": "seogen-ai",
  "version": "1.0.0",
  "description": "SEO AI Content Generator - Desktop App for Windows",
  "main": "dist-electron/main.js",
  "author": "SEOGEN Team",
  "private": true,
  "scripts": {
    "dev:web": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "preview": "vite preview",
    "lint": "eslint src electron --ext .ts,.tsx",
    "postinstall": "electron-rebuild -f -w sharp",
    "migrate": "node -r ts-node/register electron/services/db/migrate.ts latest",
    "migrate:rollback": "node -r ts-node/register electron/services/db/migrate.ts rollback",
    "migrate:make": "node -r ts-node/register electron/services/db/migrate.ts make"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-store": "8.1.0",
    "knex": "^3.1.0",
    "lucide-react": "^0.460.0",
    "marked": "^14.0.0",
    "mysql2": "^3.11.4",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "turndown": "^7.2.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^8.0.1"
  }
}
